# Postgres
POSTGRES_USER=letta
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=letta

# Chat model: llama.cpp llama-server (vLLM-compatible API) on the host
VLLM_API_BASE=http://host.docker.internal:8080
# Embeddings: host Ollama (nomic-embed-text)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Model handles used when creating the agent (see 55-create-agent.sh):
#   chat:      vllm/qwen3.6-35b-a3b
#   embedding: ollama/nomic-embed-text
LETTA_MODEL=qwen3.6-35b-a3b
# Letta server admin token (the gateway will use this later, M1b)
LETTA_SERVER_PASSWORD=change-me-strong-random

# Gateway (M1b)
SWIFTY_AGENT_ID=agent-xxxxxxxx          # from ~/swifty-infra/agent_id.txt
GATEWAY_DEVICE_TOKENS=                   # comma-separated; generate with: openssl rand -hex 32
